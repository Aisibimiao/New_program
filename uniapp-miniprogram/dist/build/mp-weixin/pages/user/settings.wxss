.settings-container{min-height:100vh;background-color:#f5f5f5;padding:20rpx}.menu-group{background-color:#fff;border-radius:20rpx;margin-bottom:20rpx;overflow:hidden}.menu-item{display:flex;align-items:center;padding:30rpx;border-bottom:1rpx solid #f0f0f0}.menu-item:last-child{border-bottom:none}.menu-icon{font-size:36rpx;margin-right:20rpx}.menu-label{flex:1;font-size:28rpx;color:#333}.logout-text{color:#ff4d4f}.menu-value{font-size:26rpx;color:#999;margin-right:10rpx}.menu-arrow{font-size:36rpx;color:#ccc}.menu-switch{transform:scale(.9)}.popup-mask{position:fixed;top:0;left:0;right:0;bottom:0;background-color:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:99999}.popup-content{width:680rpx;max-height:80vh;background-color:#fff;border-radius:20rpx;overflow:hidden;display:flex;flex-direction:column}.popup-header{padding:30rpx;text-align:center;background-color:#fff;border-bottom:1rpx solid #f0f0f0}.popup-title{font-size:32rpx;font-weight:700;color:#333}.popup-body{flex:1;padding:30rpx 15rpx 30rpx 30rpx;max-height:60vh;box-sizing:border-box;word-break:break-all;-webkit-overflow-scrolling:touch;width:calc(100% + 15rpx);margin-right:-5rpx}.popup-body::-webkit-scrollbar{display:none;width:0;height:0;background:transparent}.popup-text{line-height:1.8}.text-line{display:block;font-size:28rpx;color:#333;margin-bottom:12rpx}.empty-line{height:15rpx}.popup-footer{padding:25rpx 30rpx}.popup-btn{text-align:center;padding:25rpx;background:linear-gradient(180deg,#ff6b6b,#ff4757);color:#fff;border-radius:10rpx;font-size:30rpx;font-weight:700}
